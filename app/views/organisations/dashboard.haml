.container.mt-5
  %h1.text-center.mb-4 My Opportunities

  - if @opportunities.any?
    - @opportunities.each do |opportunity|
      .card.mb-3
        .card-body
          %h5.card-title= opportunity.title
          %p.card-text= opportunity.description.truncate(100)
          %p.text-muted Location: #{opportunity.location}
          %div
            = link_to "Edit", edit_opportunity_path(opportunity), class: "btn btn-warning btn-sm me-2"
            = link_to "Delete", opportunity_path(opportunity), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm me-2"
            = link_to "View Applications", applications_for_org_opportunity_path(opportunity), class: "btn btn-primary btn-sm"


  - else
    %p.text-center You haven't posted any opportunities yet.
    = link_to "Post an Opportunity", new_opportunity_path, class: "btn btn-success"
%div.mt-3.text-center
  = link_to "Search Volunteers", volunteers_organisations_path, class: "btn btn-success"