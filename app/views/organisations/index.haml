.container.mt-5
  %h1.text-center.mb-4 All Organisations

  / 🔎 Search form
  = form_with url: organisations_path, method: :get, local: true, class: "row g-3 mb-4" do |f|
    .col-md-4
      = f.label :name, "Search by Name"
      = f.text_field :name, value: params[:name], class: "form-control", placeholder: "Organisation Name"

    .col-md-4
      = f.label :location, "Search by Location"
      = f.text_field :location, value: params[:location], class: "form-control", placeholder: "City, State"

    .col-md-4.d-flex.align-items-end
      = f.submit "Search", class: "btn btn-primary me-2"
      = link_to "Reset", organisations_path, class: "btn btn-secondary"

  - if @organisations.any?
    .row.row-cols-1.row-cols-md-2.g-4
      - @organisations.each do |org|
        .col
          .card.h-100
            .card-body
              %h5.card-title= org.name
              %p.card-text= truncate(org.description, length: 120)
              %p.mb-1
                %strong Total Opportunities:
                = org.opportunities.count
              - if org.location.present?
                %p.mb-1
                  %strong Location:
                  = org.location
              = link_to "View Opportunities", opportunities_organisation_path(org), class: "btn btn-outline-primary mt-2"
  - else
    %p.text-muted No organisations found.

  / Back button at the bottom
  .mt-4
    = link_to "Back", root_path, class: "btn btn-secondary"