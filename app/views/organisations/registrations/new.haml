.container.mt-5
  .row.justify-content-center
    .col-lg-6
      %h2.mb-4 Organisation Sign Up

      = form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f|
        = render "devise/shared/error_messages", resource: resource

        / Email
        .mb-3
          = f.label :email, class: "form-label"
          = f.email_field :email, class: "form-control", autofocus: true

        / Phone Number
        .mb-3
          = f.label :phone_number, class: "form-label"
          = f.telephone_field :phone_number, class: "form-control"

        / Address
        .mb-3
          = f.label :address, class: "form-label"
          = f.text_field :address, class: "form-control"

        / Password
        .mb-3
          = f.label :password, class: "form-label"
          - if @minimum_password_length
            %small.text-muted
              = "(Minimum #{@minimum_password_length} characters)"
          = f.password_field :password, autocomplete: "new-password", class: "form-control"

        / Password Confirmation
        .mb-3
          = f.label :password_confirmation, class: "form-label"
          = f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control"

        / Submit button
        = f.submit "Sign up", class: "btn btn-success mt-3 w-100"

      %p.text-center.mt-3
        Already have an account?
        = link_to "Log in", new_organisation_session_path, class: "text-decoration-none"
