.container.mt-5
  %h1.mb-4 Updates for "#{@application.opportunity.title}"

  - if @updates.any?
    %ul.list-group
      - @updates.each do |update|
        %li.list-group-item
          %strong= "#{update.user_type} (#{update.created_at.strftime('%d %b %Y %H:%M')})"
          %p= update.message
  - else
    %p.text-muted No updates yet.

  .mt-3
    = link_to "View Opportunity", opportunity_path(@application.opportunity),
      class: "btn btn-secondary me-2"
    = link_to "Back to My Applications", dashboard_path,
      class: "btn btn-primary"